#!/usr/bin/env bash
set -euo pipefail

parse_args() {
	local raw_dir="${1:-$PWD}"
	if [[ ! -d "$raw_dir" ]]; then
		echo "mojave: error: directory not found: $raw_dir" >&2
		return 1
	fi
	# shellcheck disable=SC2034
	PROJECT_DIR="$(realpath "$raw_dir")"
}

# Allow override in tests.
# shellcheck disable=SC2034
OPENCODE_BIN="${OPENCODE_BIN:-$HOME/.opencode/bin/opencode}"
# shellcheck disable=SC2034
GLOBAL_CONFIG_DIR="${GLOBAL_CONFIG_DIR:-$HOME/.config/opencode}"
# shellcheck disable=SC2034
OPENCODE_DATA_DIR="${OPENCODE_DATA_DIR:-$HOME/.local/share/opencode}"
# shellcheck disable=SC2034
CONTAINER_IMAGE="${CONTAINER_IMAGE:-ubuntu:24.04}"

check_prerequisites() {
	local missing=0

	if ! command -v podman &>/dev/null; then
		echo "mojave: error: podman not found on PATH" >&2
		missing=1
	fi

	if ! command -v jq &>/dev/null; then
		echo "mojave: error: jq not found on PATH" >&2
		missing=1
	fi

	if [[ ! -x "$OPENCODE_BIN" ]]; then
		echo "mojave: error: opencode binary not found or not executable: $OPENCODE_BIN" >&2
		missing=1
	fi

	return "$missing"
}

generate_config() {
	# shellcheck disable=SC2034
	SANDBOX_CONFIG_FILE="$(mktemp --suffix=.json)"

	jq '. * {
        "permission": {
            "bash": {
                "*":               "allow",
                "curl *":          "ask",
                "wget *":          "ask",
                "ssh *":           "ask",
                "scp *":           "ask",
                "rm *":            "ask",
                "git push*":       "ask",
                "git pull*":       "ask",
                "git fetch*":      "ask",
                "git clone*":      "ask",
                "npm *":           "ask",
                "yarn *":          "ask",
                "pip*":            "ask",
                "cargo *":         "ask",
                "apt*":            "ask",
                "yum*":            "ask",
                "brew*":           "ask",
                "docker *":        "ask",
                "docker-compose*": "ask",
                "chmod*":          "ask",
                "chown*":          "ask",
                "mv *":            "ask",
                "cp -f*":          "ask",
                "find * -exec*":   "ask"
            },
            "read":       "allow",
            "edit":       "allow",
            "write":      "allow",
            "glob":       "allow",
            "grep":       "allow",
            "webfetch":   "allow",
            "websearch":  "allow"
        }
    }' "$GLOBAL_CONFIG_DIR/opencode.json" >"$SANDBOX_CONFIG_FILE"
}

_preamble_text() {
	cat <<'PREAMBLE'
# MOJAVE:START
## Sandbox Context

You are running inside a Podman sandbox launched by mojave. Your filesystem access is
limited to the following paths: the current project directory (read-write),
~/.config/opencode/ (read-write for AGENTS.md, read-only for opencode.json), and
~/.local/share/opencode/ (read-write, for session data and credentials). All other
paths on the filesystem are inaccessible.

The following operations are auto-allowed and do not require confirmation: file reads,
writes, edits, glob, grep, webfetch, websearch, and general bash commands.

The following operations still require confirmation: curl, wget, ssh, scp, rm, package
managers (npm, pip, apt, cargo, yarn, brew), chmod, chown.

Git: local operations (add, commit, diff, log, status, checkout) are auto-allowed. Any
operation that touches a remote (push, pull, fetch, clone) requires confirmation.

Docker is not available in this environment. If a task requires Docker, do not attempt
to run the command. Instead, provide the user with the exact Docker command they should
run on the host so they can copy and paste it directly.

Do not make architectural or structural design decisions without checking with the user
first. This includes creating new files that were not explicitly requested - file
creation is a design decision. If a task requires decisions about project structure,
dependency choices, framework selection, new file creation, or any change beyond the
immediate request, surface the decision and wait for explicit confirmation before
proceeding.
# MOJAVE:END
PREAMBLE
}

inject_preamble() {
	# shellcheck disable=SC2034
	SANDBOX_AGENTS_FILE="$(mktemp --suffix=.md)"
	{
		_preamble_text
		echo ""
		cat "$GLOBAL_CONFIG_DIR/AGENTS.md"
	} >"$SANDBOX_AGENTS_FILE"
}

strip_preamble() {
	# Delete every line from MOJAVE:START to MOJAVE:END inclusive, then write back.
	# If sentinels are not present, the file is written back unchanged.
	sed '/^# MOJAVE:START$/,/^# MOJAVE:END$/d' "$SANDBOX_AGENTS_FILE" \
		>"$GLOBAL_CONFIG_DIR/AGENTS.md"
}

cleanup() {
	if [[ -n "${SANDBOX_AGENTS_FILE:-}" ]]; then
		strip_preamble
		rm -f "$SANDBOX_AGENTS_FILE"
	fi
	if [[ -n "${SANDBOX_CONFIG_FILE:-}" ]]; then
		rm -f "$SANDBOX_CONFIG_FILE"
	fi
}

launch_container() {
	local cmd=(
		podman run
		--rm
		--interactive
		--tty
		--volume "${PROJECT_DIR}:${PROJECT_DIR}"
		--volume "${OPENCODE_BIN}:${OPENCODE_BIN}:ro"
		--volume "${OPENCODE_DATA_DIR}:${OPENCODE_DATA_DIR}"
		--volume "${SANDBOX_CONFIG_FILE}:${GLOBAL_CONFIG_DIR}/opencode.json:ro"
		--volume "${SANDBOX_AGENTS_FILE}:${GLOBAL_CONFIG_DIR}/AGENTS.md"
		--workdir "${PROJECT_DIR}"
		"${CONTAINER_IMAGE}"
		"${OPENCODE_BIN}"
	)

	if [[ "${DRY_RUN:-0}" -eq 1 ]]; then
		echo "${cmd[*]}"
		return 0
	fi

	"${cmd[@]}"
}

main() {
	parse_args "$@"
	check_prerequisites
	generate_config
	inject_preamble
	trap cleanup EXIT
	launch_container
}

# Guard so sourcing in tests does not execute main.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
	main "$@"
fi
