#!/usr/bin/env bash
set -euo pipefail

parse_args() {
	# shellcheck disable=SC2034
	SESSION_HASH=""
	local raw_dir=""

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-s)
				if [[ -z "${2:-}" ]]; then
					echo "ozymandias: error: -s requires a session hash" >&2
					return 1
				fi
				if [[ ! "${2}" =~ ^ses_[[:alnum:]]+$ ]]; then
					echo "ozymandias: error: invalid session hash: ${2}" >&2
					return 1
				fi
				SESSION_HASH="${2}"
				shift 2
				;;
			-*)
				echo "ozymandias: error: unknown option: $1" >&2
				return 1
				;;
			*)
				raw_dir="$1"
				shift
				;;
		esac
	done

	raw_dir="${raw_dir:-$PWD}"
	if [[ ! -d "$raw_dir" ]]; then
		echo "ozymandias: error: directory not found: $raw_dir" >&2
		return 1
	fi
	# shellcheck disable=SC2034
	PROJECT_DIR="$(realpath "$raw_dir")"
	if [[ "$PROJECT_DIR" == *:* ]]; then
		echo "ozymandias: error: project path contains a colon, which is not supported: $PROJECT_DIR" >&2
		return 1
	fi
}

# Allow override in tests. If not set, prefer the default install path; fall
# back to whatever is on PATH.
# shellcheck disable=SC2034
if [[ -z "${OPENCODE_BIN:-}" ]]; then
	if [[ -x "$HOME/.opencode/bin/opencode" ]]; then
		OPENCODE_BIN="$HOME/.opencode/bin/opencode"
	else
		OPENCODE_BIN="$(realpath "$(command -v opencode)" 2>/dev/null || true)"
	fi
fi
# shellcheck disable=SC2034
GLOBAL_CONFIG_DIR="${GLOBAL_CONFIG_DIR:-$HOME/.config/opencode}"
# shellcheck disable=SC2034
OPENCODE_DATA_DIR="${OPENCODE_DATA_DIR:-$HOME/.local/share/opencode}"
# shellcheck disable=SC2034
CONTAINER_IMAGE="${CONTAINER_IMAGE:-ubuntu:24.04}"
# shellcheck disable=SC2034
OZYMANDIAS_POLICY_FILE="${OZYMANDIAS_POLICY_FILE:-$(dirname "$(realpath "${BASH_SOURCE[0]}")")/ozymandias-policy.json}"

check_prerequisites() {
	local missing=0

	if ! command -v podman &>/dev/null; then
		echo "ozymandias: error: podman not found on PATH" >&2
		missing=1
	fi

	if ! command -v jq &>/dev/null; then
		echo "ozymandias: error: jq not found on PATH" >&2
		missing=1
	fi

	if [[ ! -x "$OPENCODE_BIN" ]]; then
		echo "ozymandias: error: opencode binary not found or not executable: $OPENCODE_BIN" >&2
		missing=1
	fi

	if [[ ! -f "$OZYMANDIAS_POLICY_FILE" ]]; then
		echo "ozymandias: error: policy file not found: $OZYMANDIAS_POLICY_FILE" >&2
		missing=1
	fi

	return "$missing"
}

generate_config() {
	# shellcheck disable=SC2034
	SANDBOX_CONFIG_FILE="$(mktemp --suffix=.json)"

	# Floor: constraints that cannot be weakened by user policy.
	# Covers destructive file ops, git remote ops, and network tools - the
	# operations that can cause lasting harm even within the container.
	local floor
	floor=$(cat <<'EOF'
{
    "cp -f*":        "ask",
    "curl *":        "ask",
    "find * -exec*": "ask",
    "git clone*":    "ask",
    "git fetch*":    "ask",
    "git pull*":     "ask",
    "git push*":     "ask",
    "mv *":          "ask",
    "rm *":          "ask",
    "scp *":         "ask",
    "ssh *":         "ask",
    "wget *":        "ask"
}
EOF
)

	jq --slurpfile policy "$OZYMANDIAS_POLICY_FILE" --argjson floor "$floor" \
		'. * $policy[0] | .permission.bash += $floor' \
		"$GLOBAL_CONFIG_DIR/opencode.json" >"$SANDBOX_CONFIG_FILE"
}

_preamble_text() {
	cat <<PREAMBLE
# OZYMANDIAS:START
## Sandbox Context

You are running inside a Podman sandbox launched by ozymandias. Your filesystem access is
limited to the following paths: the current project directory (read-write),
$GLOBAL_CONFIG_DIR/ (read-write for AGENTS.md, read-only for opencode.json), and
$OPENCODE_DATA_DIR/ (read-write for session data and runtime files; auth.json
and bin/ within that directory are read-only). All other
paths on the filesystem are inaccessible.

File operations (read, write, edit, glob, grep), webfetch, and websearch are
auto-allowed. For bash, the following are auto-allowed: file inspection (ls, cat,
head, tail, stat, diff, wc, du, df), text processing (grep, sed, awk, sort, uniq,
cut, tr), shell utilities (echo, printf, pwd, env, date, which, whoami, ps),
directory creation (mkdir, touch), git local operations (add, commit, diff, log,
status, checkout, branch, stash, merge, rebase, show, tag, config), and common
language runtimes (python, node, ruby, go, make, bash, sh). All other bash commands
require confirmation.

The following operations always require confirmation regardless of any other setting:
file removal and overwriting (rm, mv, cp -f, find -exec), network tools (curl, wget,
ssh, scp), and git remote operations (push, pull, fetch, clone).

Docker is not available in this environment. If a task requires Docker, do not attempt
to run the command. Instead, provide the user with the exact Docker command they should
run on the host so they can copy and paste it directly.

Do not make architectural or structural design decisions without checking with the user
first. This includes creating new files that were not explicitly requested - file
creation is a design decision. If a task requires decisions about project structure,
dependency choices, framework selection, new file creation, or any change beyond the
immediate request, surface the decision and wait for explicit confirmation before
proceeding.
# OZYMANDIAS:END
PREAMBLE
}

inject_preamble() {
	# shellcheck disable=SC2034
	SANDBOX_AGENTS_FILE="$(mktemp --suffix=.md)"
	{
		_preamble_text
		echo ""
		cat "$GLOBAL_CONFIG_DIR/AGENTS.md"
	} >"$SANDBOX_AGENTS_FILE"
}

strip_preamble() {
	# Delete every line from OZYMANDIAS:START to OZYMANDIAS:END inclusive, then write back.
	# If sentinels are not present, the file is written back unchanged.
	local tmp
	tmp="$(mktemp --suffix=.md)"
	sed '/^# OZYMANDIAS:START$/,/^# OZYMANDIAS:END$/d' "$SANDBOX_AGENTS_FILE" >"$tmp"
	mv "$tmp" "$GLOBAL_CONFIG_DIR/AGENTS.md"
}

cleanup() {
	if [[ -n "${SANDBOX_AGENTS_FILE:-}" ]]; then
		strip_preamble
		rm -f "$SANDBOX_AGENTS_FILE"
	fi
	if [[ -n "${SANDBOX_CONFIG_FILE:-}" ]]; then
		rm -f "$SANDBOX_CONFIG_FILE"
	fi
}

launch_container() {
	local cmd=(
		podman run
		--rm
		--interactive
		--tty
		--env "HOME=${HOME}"
		--env "TERM=${TERM:-xterm-256color}"
		--env "COLORTERM=${COLORTERM:-truecolor}"
		--volume "${PROJECT_DIR}:${PROJECT_DIR}"
		--volume "${OPENCODE_BIN}:${OPENCODE_BIN}:ro"
		--volume "${OPENCODE_DATA_DIR}:${OPENCODE_DATA_DIR}"
		--volume "${GLOBAL_CONFIG_DIR}:${GLOBAL_CONFIG_DIR}:ro"
		--volume "${SANDBOX_CONFIG_FILE}:${GLOBAL_CONFIG_DIR}/opencode.json:ro"
		--volume "${SANDBOX_AGENTS_FILE}:${GLOBAL_CONFIG_DIR}/AGENTS.md"
		--workdir "${PROJECT_DIR}"
	)

	if [[ -f "${HOME}/.gitconfig" ]]; then
		cmd+=(--volume "${HOME}/.gitconfig:${HOME}/.gitconfig:ro")
	fi

	# Overlay read-only paths on top of the read-write data dir mount.
	# More specific bind mounts shadow broader ones, so the data dir remains
	# writable for the session database and other runtime files.
	if [[ -f "${OPENCODE_DATA_DIR}/auth.json" ]]; then
		cmd+=(--volume "${OPENCODE_DATA_DIR}/auth.json:${OPENCODE_DATA_DIR}/auth.json:ro")
	fi
	if [[ -d "${OPENCODE_DATA_DIR}/bin" ]]; then
		cmd+=(--volume "${OPENCODE_DATA_DIR}/bin:${OPENCODE_DATA_DIR}/bin:ro")
	fi

	cmd+=("${CONTAINER_IMAGE}" "${OPENCODE_BIN}")
	if [[ -n "${SESSION_HASH:-}" ]]; then
		cmd+=(-s "${SESSION_HASH}")
	fi

	if [[ "${DRY_RUN:-0}" -eq 1 ]]; then
		printf '%q ' "${cmd[@]}"
		printf '\n'
		return 0
	fi

	local marker_file exit_code=0
	marker_file="$(mktemp)"
	"${cmd[@]}" || exit_code=$?

	local next_session=""
	if [[ -n "${SESSION_HASH:-}" ]]; then
		next_session="$SESSION_HASH"
	else
		next_session=$(find "$OPENCODE_DATA_DIR" -newer "$marker_file" 2>/dev/null \
			| grep -oE 'ses_[[:alnum:]]+' | sort -u | head -1)
	fi
	rm -f "$marker_file"

	if [[ -n "$next_session" ]]; then
		printf '  \033[90mResume\033[0m    ozymandias -s %s %s\n\n' \
			"$next_session" "${PROJECT_DIR}"
	fi

	return "$exit_code"
}

warn_gitconfig_includes() {
	if [[ -f "${HOME}/.gitconfig" ]] && grep -q '^\[include' "${HOME}/.gitconfig"; then
		echo "ozymandias: warning: ~/.gitconfig contains [include] directives; included files will not be available in the container" >&2
	fi
}

main() {
	parse_args "$@"
	check_prerequisites
	warn_gitconfig_includes
	trap cleanup EXIT
	generate_config
	inject_preamble
	launch_container
}

# Guard so sourcing in tests does not execute main.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
	main "$@"
fi
